# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
ENV/

# Packaging / install metadata (regenerated by pip)
*.egg-info/
*.egg
build/
dist/

# Translation cache (default location under the package)
translate_code/cache/cache.json

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store

# Backups from --backup
*.bak
*.ipynb.bak

# Optional local env files (secrets — never commit)
.env
.env.local
.translate-code.env

# Pytest / coverage (if added later)
.pytest_cache/
.coverage
htmlcov/
